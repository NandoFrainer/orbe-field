# ─── Variáveis de ambiente (NUNCA versionar) ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
functions/.env

# ─── Credenciais de Service Account ─────────────────────────────────────────
# Ignorar somente arquivos sensíveis — NÃO usar *.json genérico
# pois isso ignoraria package.json, tsconfig.json, components.json, etc.
service-account*.json
*-service-account*.json
orbe-field-*.json
*.pem
*.key

# ─── Next.js ──────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Node modules ─────────────────────────────────────────────────────────────
node_modules/
functions/node_modules/

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Misc ─────────────────────────────────────────────────────────────────────
.DS_Store
.vercel
*.tsbuildinfo
