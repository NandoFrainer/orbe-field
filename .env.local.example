# ─── Firebase Client (público — NEXT_PUBLIC_*) ────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=orbe-field.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=orbe-field
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=orbe-field.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (server-side apenas) ──────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=orbe-field
FIREBASE_ADMIN_CLIENT_EMAIL=orbe-sheets-sync@orbe-field.iam.gserviceaccount.com
# Cole a private_key do JSON baixado (manter as \n literais, entre aspas)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── Google Sheets (mesma Service Account) ────────────────────────────────────
# SOMENTE LEITURA — scope: spreadsheets.readonly
GOOGLE_SA_EMAIL=orbe-sheets-sync@orbe-field.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Criar conta gratuita em https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
